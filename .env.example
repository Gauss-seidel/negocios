# Supabase (Frontend - Vite)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-de-supabase

# Google reCAPTCHA (opcional - para proteger login contra fuerza bruta)
# Activá CAPTCHA en Supabase Dashboard > Authentication > Settings > CAPTCHA protection
# Site Key aparece ahí mismo al activarlo
# VITE_RECAPTCHA_SITE_KEY=6Le...

# Scripts de setup (Node - SOLO local, NUNCA en Render/producción)
# Copia a .env.local y usa SUPABASE_SERVICE_ROLE_KEY de Supabase Dashboard > Settings > API
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
